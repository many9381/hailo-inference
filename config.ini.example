[mode]
; Select the runtime role: "server" or "client"
role = client

[server]
; Path to the Hailo HEF model (used only in server mode)
hef_path = models/yolov8n.hef
; Video source for inference. The following three formats are supported:
;   1) File path    : resource/video.mp4  (uses resource/sample.mp4 if left empty)
;   2) V4L2 device  : /dev/video0         (such as a USB webcam)
;   3) RTSP URL     : rtsp://host:port/path
video_path =

[rtsp]
; RTSP server port (used by both server for streaming and client for receiving)
port = 8554
; RTSP stream path
stream_path = /stream
; RTP transport protocol: "udp" or "tcp" (TCP interleaved)
protocol = udp

[client]
; IP address of the server to connect to (used only in client mode)
; If left empty, enter it directly in the GUI.
server_ip = 127.0.0.1
